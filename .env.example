APP_NAME=
ENVIRONMENT=
DATABASE_URL=
LOG_LEVEL=
RELOAD=
HOST=
PORT=
DEBUG=
METRICS_ENABLED=false
SENTRY_DSN=
# Required when running the seed-admin Alembic migration (`alembic upgrade head`).
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_FIRST_NAME=Admin
SEED_ADMIN_LAST_NAME=User
# Required for POST /library/books/ai/enrich (Google Gemini).
GEMINI_API_KEY=
GEMINI_MODEL=
# Optional API root override (default: https://generativelanguage.googleapis.com/v1beta)
# GEMINI_BASE_URL=
# Optional: HTTP read timeout for Gemini (seconds, default 180, max 600)
# GEMINI_HTTP_TIMEOUT_SECONDS=180
# Retries for 429 / 5xx (default 5). Backoff honors Retry-After when present.
# GEMINI_MAX_RETRIES=5
# GEMINI_RETRY_BACKOFF_BASE_SECONDS=1
# GEMINI_RETRY_BACKOFF_MAX_SECONDS=60
# Serialize Gemini calls per worker (default true; reduces rate-limit bursts)
# GEMINI_SERIALIZE_REQUESTS=true
# Open Library (ISBN lookup before AI enrich; no API key). Optional overrides:
# OPEN_LIBRARY_BASE_URL=https://openlibrary.org
# ISBN_LOOKUP_TIMEOUT_SECONDS=12
